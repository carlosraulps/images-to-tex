{
  "name": "docs-to-code",
  "version": "1.0.0",
  "description": "An Agent Skill providing tools to convert images of textbooks, handwritten equations, and notes into LaTeX or Markdown.",
  "mcpServers": {
    "docs-to-code": {
      "command": "/Users/apple/venvs/research/bin/python3",
      "args": [
        "/Users/apple/Research/docs-to-code/src/interfaces/mcp_server.py"
      ],
      "env": {
        "PYTHONPATH": "/Users/apple/Research/docs-to-code",
        "GOOGLE_API_KEY": "${GOOGLE_API_KEY}"
      }
    }
  }
}
